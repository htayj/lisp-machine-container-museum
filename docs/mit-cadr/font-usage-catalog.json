  "status_definitions": {
    "direct-runtime": "Executable CADR Lisp code selects the font for an identified role.",
    "cross-version-direct-runtime": "Executable maintained LM-3 source selects the same logical font for an identified role, but the primary System 46 snapshot lacks that selector and compiled byte identity is unproved.",
    "document-output-name-match": "A document or formatter selects a resource with the same name, but the snapshot does not prove that the printer resource is the recovered screen-font raster.",
    "documented-use": "Contemporary documentation or a bug report identifies a role, but no executable selector survives in the primary System 46 source snapshot.",
    "reported-use-no-purpose": "Contemporary material establishes use or runtime presence without identifying a purpose.",
    "standard-load-no-purpose": "A system package or loader includes the font, but no consuming role was found.",
    "source-build-only": "The font occurs in the source archive compilation list, but no consuming role was found.",
    "source-only": "A recoverable source representation exists, but no build-list, load, or consuming-role reference was found.",
    "compiled-inventory-only": "A compiled font is inventoried, but no load or consuming-role reference was found."
  },
